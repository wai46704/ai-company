---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | My Blog" description="お問い合わせページ">
  <section class="contact">
    <div class="contact-icon">📬</div>
    <h1>Contact</h1>
    <p class="subtitle">お気軽にご連絡ください！</p>

    <div class="contact-card">
      <form class="contact-form" action="#" method="POST">
        <div class="field">
          <label for="name">お名前</label>
          <input type="text" id="name" name="name" placeholder="山田 太郎" required />
        </div>
        <div class="field">
          <label for="email">メールアドレス</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="field">
          <label for="message">メッセージ</label>
          <textarea id="message" name="message" rows="5" placeholder="メッセージをどうぞ..." required></textarea>
        </div>
        <button type="submit" class="btn">送信する 🚀</button>
      </form>
    </div>

    <p class="note">※ このフォームはデモ用です。実際の送信機能を追加するには、フォームサービス（Formspree等）と連携してください。</p>
  </section>
</BaseLayout>

<style>
  .contact {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 2rem 0;
  }

  .contact-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.2rem;
    color: #6c63ff;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .contact-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 24px rgba(108, 99, 255, 0.1);
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .field {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 0.4rem;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: 2px solid #e8e4ff;
    border-radius: 10px;
    font-family: inherit;
    font-size: 0.97rem;
    color: var(--color-text);
    transition: border-color 0.2s;
    background: #faf9ff;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: #6c63ff;
    background: #fff;
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn {
    display: inline-block;
    width: 100%;
    padding: 0.75rem;
    background: linear-gradient(135deg, #6c63ff, #a855f7);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s, transform 0.15s;
    text-align: center;
  }

  .btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .note {
    font-size: 0.82rem;
    color: #bbb;
  }
</style>
